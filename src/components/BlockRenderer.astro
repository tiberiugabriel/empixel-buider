---
import type { SectionBlock } from "../types.js";
import Testimonials from "./Testimonials.astro";
import FaqSection from "./FaqSection.astro";
import PricingSection from "./PricingSection.astro";
import SpacerSection from "./SpacerSection.astro";
import { buildBlockStyle, buildHoverCss, getVideoBackground, getBlockId, getBlockClass, getCustomCss } from "./styleUtils.js";

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const LEAF_COMPONENTS: Record<string, any> = {
  testimonials: Testimonials,
  faq: FaqSection,
  pricing: PricingSection,
  spacer: SpacerSection,
};

interface Props {
  block: SectionBlock;
}

const { block } = Astro.props;
const Component = LEAF_COMPONENTS[block.type];

const config  = block.config as Record<string, unknown>;
const inlineStyle = buildBlockStyle(config);
const videoSrc    = getVideoBackground(config);
const blockId     = getBlockId(config);
const extraClass  = getBlockClass(config);
const customCss   = getCustomCss(config, block.id);
const hoverCss    = buildHoverCss(config, block.id);
---

{Component && (
  <div
    data-epx-block={block.id}
    id={blockId ?? undefined}
    class={extraClass || undefined}
    style={inlineStyle || undefined}
  >
    {videoSrc && (
      <video
        autoplay
        muted
        loop
        playsinline
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;pointer-events:none;"
        src={videoSrc}
      />
    )}
    <div style={videoSrc ? "position:relative;z-index:1;" : undefined}>
      <Component value={block.config} />
    </div>
  </div>
)}

{customCss && <style set:html={customCss} is:global />}
{hoverCss && <style set:html={hoverCss} is:global />}
