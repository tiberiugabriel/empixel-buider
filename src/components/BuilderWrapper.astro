---
import type { SectionBlock } from "../types.js";
import type { BuilderLayoutResult } from "./db.js";
import LayoutRenderer from "./LayoutRenderer.astro";

// `sections` accepts three shapes for transitional compatibility:
//
//   1. `BuilderLayoutResult` ({ sections, cacheHint }) — the value
//      returned by the v0.8 sync `getBuilderLayout` AND the resolved
//      value of the v0.9 (F3.4) async `getBuilderLayout`. Hosts that
//      `await getBuilderLayout(Astro, ...)` and pass the result straight
//      through land here.
//   2. `Promise<BuilderLayoutResult>` — convenience for hosts that
//      forget the `await`. The wrapper resolves it for them. Wraps the
//      v0.9 async signature so the most common slip ("I forgot to
//      await") still renders.
//   3. Legacy `SectionBlock[] | null` shape — pre-v0.8 frontmatter
//      from `npx empixel-builder add` scaffolds. No `cacheHint` plumbed
//      because the legacy shape never carried one.
interface Props {
  sections:
    | BuilderLayoutResult
    | Promise<BuilderLayoutResult>
    | SectionBlock[]
    | null
    | undefined;
}

const { sections: rawProp } = Astro.props;

// Resolve the promise-shape up front so the rest of the file sees a
// concrete `BuilderLayoutResult | SectionBlock[] | null`. Astro
// frontmatter is allowed to `await`, so we lean on that here.
const prop =
  rawProp && typeof (rawProp as Promise<BuilderLayoutResult>).then === "function"
    ? await (rawProp as Promise<BuilderLayoutResult>)
    : rawProp;

// Normalise to a `BuilderLayoutResult`-shaped object regardless of which
// variant the host passed. The legacy array/null path leaves `cacheHint`
// undefined — we skip the `Astro.cache.set` call in that case so callers
// who never opted in to caching don't suddenly get a hint they didn't ask for.
let resolvedSections: SectionBlock[] | null = null;
let cacheHint: { tags?: string[]; lastModified?: Date } | undefined;

if (Array.isArray(prop)) {
  resolvedSections = prop;
} else if (prop && typeof prop === "object" && "sections" in prop) {
  resolvedSections = prop.sections ?? null;
  cacheHint = prop.cacheHint;
}

// Plumb the cacheHint into Astro.cache.set so the host page invalidates
// when the admin saves a new layout. The cacheHint always carries a
// `empixel:layout:<collection>:<entryId>` tag (and `lastModified` when
// the row exists) — set unconditionally so a fresh layout still busts
// the cache once it's saved for the first time.
//
// Astro's `cache.set` is best-effort; some adapters omit it. Guard the
// access so the wrapper still renders on adapters without caching.
if (cacheHint) {
  const cache = (Astro as unknown as { cache?: { set?: (hint: unknown) => void } }).cache;
  if (typeof cache?.set === "function") {
    cache.set(cacheHint);
  }
}
---

{resolvedSections ? <LayoutRenderer sections={resolvedSections} /> : <slot />}
