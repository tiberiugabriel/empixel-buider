---
import type { ColumnsConfig, SectionBlock } from "../types.js";
import BlockRenderer from "./BlockRenderer.astro";

interface Props {
  value: ColumnsConfig;
  slots?: SectionBlock[][];
}

const { value, slots } = Astro.props;
const { columns = "2", theme = "light" } = value;
const numCols = parseInt(columns, 10);

// Use slots (nested block format) if any slot has content
const useSlots = slots && slots.some((slot) => slot.length > 0);

// Build column data for template
type ColData = { key: number; blocks: SectionBlock[] | null; legacyText: string };
const colData: ColData[] = [];
for (let i = 0; i < numCols; i++) {
  colData.push({
    key: i,
    blocks: useSlots ? (slots![i] ?? []) : null,
    legacyText: useSlots ? "" : ((value[`col${i + 1}Content` as keyof ColumnsConfig] as string) ?? ""),
  });
}

function renderParas(text: string) {
  return text.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
}
---

<section class={`epx-columns epx-theme--${theme}`}>
  <div class={`epx-columns__inner epx-container epx-columns--${columns}`}>
    {colData.map((col) => (
      <div class="epx-col">
        {col.blocks !== null ? (
          col.blocks.map((block) => <BlockRenderer block={block} />)
        ) : (
          renderParas(col.legacyText).map((p) => <p>{p}</p>)
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .epx-columns { padding: 60px 0; }
  .epx-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .epx-columns__inner { display: grid; gap: 48px; }
  .epx-columns--2 { grid-template-columns: 1fr 1fr; }
  .epx-columns--3 { grid-template-columns: 1fr 1fr 1fr; }
  @media (max-width: 768px) {
    .epx-columns--3 { grid-template-columns: 1fr; }
    .epx-columns--2 { grid-template-columns: 1fr; }
  }

  .epx-col p {
    font-size: 1rem;
    line-height: 1.75;
    opacity: 0.8;
    margin: 0 0 16px;
  }
  .epx-col p:last-child { margin-bottom: 0; }

  .epx-theme--light { background: #fff; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--accent { background: #f8f9fb; color: #111; }
</style>
