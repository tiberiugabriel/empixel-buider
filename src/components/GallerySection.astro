---
import type { GalleryConfig } from "../types.js";
import { parseItems } from "../types.js";

interface Props {
  value: GalleryConfig;
}

const { value } = Astro.props;
const { headline, columns = "3", theme = "light" } = value;
const images = parseItems(value.images);
---

<section class={`epx-gallery epx-theme--${theme}`}>
  <div class="epx-container">
    {headline && (
      <div class="epx-section-header">
        <h2 class="epx-section-title">{headline}</h2>
      </div>
    )}
    <div class={`epx-gallery__grid epx-gallery__grid--cols-${columns}`}>
      {images.map((img) => (
        <figure class="epx-gallery__figure">
          <img
            src={img.url}
            alt={img.alt}
            class="epx-gallery__img"
            loading="lazy"
          />
          {img.caption && <figcaption class="epx-gallery__caption">{img.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .epx-gallery { padding: 80px 0; }
  .epx-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .epx-section-header { text-align: center; margin-bottom: 36px; }
  .epx-section-title { font-size: 2rem; font-weight: 800; margin: 0; }

  .epx-gallery__grid {
    display: grid;
    gap: 16px;
  }
  .epx-gallery__grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .epx-gallery__grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .epx-gallery__grid--cols-4 { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 768px) {
    .epx-gallery__grid--cols-3,
    .epx-gallery__grid--cols-4 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .epx-gallery__grid { grid-template-columns: 1fr !important; }
  }

  .epx-gallery__figure { margin: 0; display: flex; flex-direction: column; }
  .epx-gallery__img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }
  .epx-gallery__caption {
    font-size: 0.82rem;
    opacity: 0.6;
    text-align: center;
    padding: 6px 0 0;
    margin: 0;
  }

  .epx-theme--light { background: #fff; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--accent { background: #f8f9fb; color: #111; }
</style>
