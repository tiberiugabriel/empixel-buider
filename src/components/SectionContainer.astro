---
import type { SectionBlock } from "../types.js";
import BlockRenderer from "./BlockRenderer.astro";
import { buildBlockStyle, wrapBlockCss, buildHoverCss, getVideoBackground, getBlockId, getBlockClass, getCustomCss } from "./styleUtils.js";

interface Props {
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  value: Record<string, any>;
  children?: SectionBlock[];
  blockId?: string;
}

const { value, children = [], blockId = "" } = Astro.props;

const style = (value.style ?? {}) as Record<string, unknown>;

// Padding: prefer style.* (new system), fall back to named spacingMap (old system)
const spacingMap: Record<string, string> = {
  none: "0", sm: "32px", md: "48px", lg: "64px", xl: "96px",
};
function resolveSpacing(styleVal: unknown, legacyKey: string): string {
  const sv = typeof styleVal === "string" && styleVal && !styleVal.startsWith("@@") ? styleVal
    : typeof styleVal === "string" && styleVal.startsWith("@@") ? styleVal.slice(2)
    : "";
  if (sv) return sv;
  return spacingMap[legacyKey] ?? "48px";
}

const paddingTop    = resolveSpacing(style.paddingTop,    value.paddingTop);
const paddingRight  = resolveSpacing(style.paddingRight,  "");
const paddingBottom = resolveSpacing(style.paddingBottom, value.paddingBottom);
const paddingLeft   = resolveSpacing(style.paddingLeft,   "");

// Build all other styles (background, margin, border, width, height, etc.)
// via buildBlockStyle, then override padding with resolved values
const fullStyle = buildBlockStyle(value);

// Compose final inline style — buildBlockStyle may include paddingTop etc.
// but we override below with our resolved values that respect both systems
const paddingCss = [
  paddingTop    ? `padding-top:${paddingTop}`      : "",
  paddingRight  ? `padding-right:${paddingRight}`  : "",
  paddingBottom ? `padding-bottom:${paddingBottom}` : "",
  paddingLeft   ? `padding-left:${paddingLeft}`    : "",
].filter(Boolean).join(";");

// Strip any padding-* the full style may have added, then append resolved padding
const styleWithoutPadding = fullStyle.replace(/padding-[^:]+:[^;]+(;|$)/g, "");
const inlineStyle = [styleWithoutPadding, paddingCss].filter(Boolean).join(";");

// Layout styles
const layoutMode = (value.layout as string) ?? "flex";
const isGrid     = layoutMode === "grid";
function resolveTrack(raw: unknown): string {
  if (typeof raw !== "string" || !raw) return "";
  if (raw.startsWith("@@")) return raw.slice(2);
  return raw;
}
function cssVal(v: unknown): string {
  if (typeof v !== "string" || !v.trim()) return "";
  const t = v.trim();
  return t.startsWith("@@") ? t.slice(2) : t;
}
const layoutParts: string[] = [`display:${isGrid ? "grid" : "flex"}`];
const colGap = cssVal(style.columnGap); if (colGap) layoutParts.push(`column-gap:${colGap}`);
const rowGap = cssVal(style.rowGap);    if (rowGap) layoutParts.push(`row-gap:${rowGap}`);
if (isGrid) {
  const flow = (value.gridFlow as string) ?? "row"; layoutParts.push(`grid-auto-flow:${flow}`);
  const ji   = (value.justifyItems as string) ?? "stretch"; layoutParts.push(`justify-items:${ji}`);
  const ai   = (value.alignItems   as string) ?? "stretch"; layoutParts.push(`align-items:${ai}`);
  const gtc  = resolveTrack(value.gridColumns); if (gtc) layoutParts.push(`grid-template-columns:${gtc}`);
  const gtr  = resolveTrack(value.gridRows);    if (gtr) layoutParts.push(`grid-template-rows:${gtr}`);
} else {
  const wrap = (value.flexWrap       as string) ?? "nowrap";     layoutParts.push(`flex-wrap:${wrap}`);
  const dir  = (value.flexDirection  as string) ?? "row";        layoutParts.push(`flex-direction:${dir}`);
  const jc   = (value.justifyContent as string) ?? "flex-start"; layoutParts.push(`justify-content:${jc}`);
  const ai   = (value.flexAlignItems as string) ?? "stretch";    layoutParts.push(`align-items:${ai}`);
}
const layoutStyle = layoutParts.join(";");

const videoSrc   = getVideoBackground(value);
const extraId    = getBlockId(value);
const extraClass = getBlockClass(value);
const customCss  = blockId ? getCustomCss(value, blockId) : "";
const hoverCss   = blockId ? buildHoverCss(value, blockId) : "";
const videoExtraCss = videoSrc ? "position:relative;overflow:hidden" : "";
const fullStyleStr  = [inlineStyle, videoExtraCss, layoutStyle].filter(Boolean).join(";");
const blockCss      = wrapBlockCss(fullStyleStr, blockId);
const allCss        = [blockCss, hoverCss, customCss].filter(Boolean).join("");

// Video options
const videoPlayOnce  = (value.backgroundVideoPlayOnce  as boolean) ?? false;
const videoStartTime = value.backgroundVideoStartTime as number | undefined;
const videoEndTime   = value.backgroundVideoEndTime   as number | undefined;
const videoFallbackKey = value.backgroundVideoFallbackStorageKey as string | undefined;
const videoPoster    = videoFallbackKey ? `/_emdash/api/media/file/${videoFallbackKey}` : undefined;
const hasVideoTiming = videoStartTime !== undefined || videoEndTime !== undefined || videoPlayOnce;
const Tag        = ((value.htmlTag as string) || "section") as astroHTML.JSX.HTMLTag;

// Link attributes (only relevant when Tag === "a")
const linkHref       = (value.linkHref       as string)  || undefined;
const linkNewTab     = (value.linkNewTab      as boolean) || false;
const linkNofollow   = (value.linkNofollow    as boolean) || false;
const linkCustomAttr = (value.linkCustomAttr  as string)  || "";
const linkTarget     = linkNewTab   ? "_blank"   : undefined;
const linkRel        = (() => {
  const parts: string[] = [];
  if (linkNewTab)   parts.push("noopener", "noreferrer");
  if (linkNofollow) parts.push("nofollow");
  return parts.length ? parts.join(" ") : undefined;
})();
const linkCustomAttrs: Record<string, string> = {};
if (linkCustomAttr) {
  for (const pair of linkCustomAttr.split(",")) {
    const sep = pair.indexOf("|");
    if (sep > 0) {
      const k = pair.slice(0, sep).trim();
      const v = pair.slice(sep + 1).trim();
      if (k) linkCustomAttrs[k] = v;
    }
  }
}
---

<Tag
  class={`epx-section-container epx-theme--${(value.theme as string) || "light"}${extraClass ? ` ${extraClass}` : ""}`}
  id={extraId ?? undefined}
  data-epx-block={blockId || undefined}
  href={linkHref}
  target={linkTarget}
  rel={linkRel}
  {...linkCustomAttrs}
>
  {videoSrc && (
    <video
      autoplay
      muted
      loop={!videoPlayOnce || undefined}
      playsinline
      poster={videoPoster}
      data-epx-start={videoStartTime !== undefined ? String(videoStartTime) : undefined}
      data-epx-end={videoEndTime !== undefined ? String(videoEndTime) : undefined}
      data-epx-once={videoPlayOnce ? "1" : undefined}
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;pointer-events:none;"
      src={videoSrc}
    />
  )}
  {videoSrc && hasVideoTiming && (
    <script is:inline>{`
      (function(){
        var v = document.currentScript.previousElementSibling;
        while(v && v.tagName !== 'VIDEO') v = v.previousElementSibling;
        if(!v) return;
        var start = v.dataset.epxStart !== undefined ? parseFloat(v.dataset.epxStart) : null;
        var end   = v.dataset.epxEnd   !== undefined ? parseFloat(v.dataset.epxEnd)   : null;
        var once  = v.dataset.epxOnce === '1';
        if(start !== null) { v.addEventListener('loadedmetadata', function(){ v.currentTime = start; }, {once:true}); }
        if(end !== null || once) {
          v.addEventListener('timeupdate', function(){
            if(end !== null && v.currentTime >= end) {
              if(once) { v.pause(); } else { v.currentTime = start !== null ? start : 0; }
            }
          });
        }
      })();
    `}</script>
  )}
  {videoSrc ? (
    <div style="position:relative;z-index:1">
      {children.map((child) =>
        child.type === "container"
          ? <Astro.self value={child.config} children={child.children ?? []} blockId={child.id} />
          : <BlockRenderer block={child} />
      )}
    </div>
  ) : children.map((child) =>
    child.type === "container"
      ? <Astro.self value={child.config} children={child.children ?? []} blockId={child.id} />
      : <BlockRenderer block={child} />
  )}
</Tag>

{allCss && <style set:html={allCss} is:global />}
