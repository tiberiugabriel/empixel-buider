---
import type { SpacerConfig } from "../types.js";

interface Props {
  value: SpacerConfig;
}

const { value } = Astro.props;
const { height = "md", showDivider = false } = value;

const heightMap = {
  sm: "32px",
  md: "64px",
  lg: "96px",
  xl: "128px",
};
const spacerHeight = heightMap[height] ?? "64px";
---

<div class="epx-spacer" style={`height: ${spacerHeight};`} aria-hidden="true">
  {showDivider && <hr class="epx-spacer__divider" />}
</div>

<style>
  .epx-spacer {
    display: flex;
    align-items: center;
    padding: 0 24px;
  }
  .epx-spacer__divider {
    width: 100%;
    border: none;
    border-top: 1px solid rgba(0,0,0,0.1);
    margin: 0;
  }
</style>
