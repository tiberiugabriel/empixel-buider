---
import type { StatsConfig } from "../types.js";
import { parseItems } from "../types.js";

interface Props {
  value: StatsConfig;
}

const { value } = Astro.props;
const { headline, theme = "light" } = value;
const items = parseItems(value.items);
---

<section class={`epx-stats epx-theme--${theme}`}>
  <div class="epx-container">
    {headline && (
      <div class="epx-section-header">
        <h2 class="epx-section-title">{headline}</h2>
      </div>
    )}
    <div class="epx-stats__grid">
      {items.map((item) => (
        <div class="epx-stat-item">
          <span class="epx-stat-item__value">{item.value}</span>
          <span class="epx-stat-item__label">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .epx-stats { padding: 80px 0; }
  .epx-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .epx-section-header { text-align: center; margin-bottom: 48px; }
  .epx-section-title { font-size: 2rem; font-weight: 800; margin: 0; }

  .epx-stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 32px;
    text-align: center;
  }

  .epx-stat-item { display: flex; flex-direction: column; gap: 6px; }
  .epx-stat-item__value {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1;
    color: #2563eb;
  }
  .epx-stat-item__label { font-size: 1rem; opacity: 0.7; font-weight: 500; }

  .epx-theme--light { background: #f8f9fb; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--dark .epx-stat-item__value { color: #60a5fa; }
  .epx-theme--accent { background: #2563eb; color: #fff; }
  .epx-theme--accent .epx-stat-item__value { color: #fff; }
</style>
