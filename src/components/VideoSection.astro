---
import type { VideoConfig } from "../types.js";
import { getEmbedUrl } from "../types.js";

interface Props {
  value: VideoConfig;
}

const { value } = Astro.props;
const { url, caption, autoplay = false, theme = "light" } = value;
const embedUrl = getEmbedUrl(url) + (autoplay ? "?autoplay=1&mute=1" : "");
---

<section class={`epx-video epx-theme--${theme}`}>
  <div class="epx-video__container epx-container">
    <div class="epx-video__wrapper">
      <iframe
        src={embedUrl}
        title={caption ?? "Video"}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
        class="epx-video__iframe"
      />
    </div>
    {caption && <p class="epx-video__caption">{caption}</p>}
  </div>
</section>

<style>
  .epx-video { padding: 60px 0; }
  .epx-container { max-width: 900px; margin: 0 auto; padding: 0 24px; }
  .epx-video__wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.15);
  }
  .epx-video__iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .epx-video__caption {
    text-align: center;
    font-size: 0.9rem;
    opacity: 0.6;
    margin: 12px 0 0;
  }

  .epx-theme--light { background: #fff; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--accent { background: #f0f4ff; color: #111; }
</style>
